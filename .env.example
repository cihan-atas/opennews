# ────────────────────────────────────────────────
# Veritabanı (Neon — ücretsiz, pgvector destekli)
# Kayıt: https://neon.tech
# ────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require
POSTGRES_USER=user
POSTGRES_PASSWORD=pass
POSTGRES_DB=news_and_podcast

# ────────────────────────────────────────────────
# Güvenlik
# ────────────────────────────────────────────────
SECRET_KEY=gizli-anahtar-buraya-yazin
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ────────────────────────────────────────────────
# Celery — Redis Broker
# Upstash ücretsiz tier: https://upstash.com
# "rediss://" (TLS) kullan
# ────────────────────────────────────────────────
CELERY_BROKER_URL=rediss://default:token@your-redis.upstash.io:6379

# ────────────────────────────────────────────────
# GCP (varsayılan AI/Embedding provider; ücretsiz kota var)
# GCP yerine OpenAI kullanmak için aşağıdaki bloku etkinleştir.
# ────────────────────────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=gcp-service-account.json
GCP_PROJECT_ID=your-project-id
GCP_BUCKET_NAME=your-bucket
GCP_LOCATION=europe-west3

# ────────────────────────────────────────────────
# Sağlayıcı Seçimi — ücretsiz stack
# ────────────────────────────────────────────────
# TTS: edge-tts (ücretsiz, Microsoft Edge sesleri, credential gerektirmez) veya polly (AWS)
TTS_PROVIDER=edge
EDGE_TTS_VOICE=tr-TR-EmelNeural

# AWS Polly (TTS_PROVIDER=polly için)
# AWS_ACCESS_KEY_ID=your-aws-access-key-id
# AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
# AWS_REGION=eu-central-1
# POLLY_VOICE_TR=Burcu
# POLLY_ENGINE=neural

# Depolama: Cloudflare R2 (10 GB/ay ücretsiz, ücretsiz egress)
# Kayıt: https://dash.cloudflare.com → R2 → yeni bucket
STORAGE_PROVIDER=s3
S3_ENDPOINT_URL=https://<accountid>.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET_NAME=newsflow-audio
S3_ACCESS_KEY_ID=r2-access-key
S3_SECRET_ACCESS_KEY=r2-secret-key
S3_PUBLIC_BASE_URL=https://pub-<hash>.r2.dev  # Public bucket CDN (opsiyonel)

# AI / Embedding: GCP Vertex varsayılan.
# Gemini API'ye geçmek için:
#   AI_PROVIDER=gemini
#   GEMINI_API_KEY=AIzaSy...
#   GEMINI_MODEL=gemini-2.5-flash
AI_PROVIDER=vertex
# vertex | openai | local | mock | none
#   local = ücretsiz yerel model (~1.5 GB RAM gerekir, semantik arama + Benzer Haberler açık)
#   none  = embedding kapalı (düşük RAM sunucu): arama kelime bazlı çalışır, Benzer Haberler kapanır
EMBEDDING_PROVIDER=vertex
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# ────────────────────────────────────────────────
# Frontend (CORS)
# ────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ────────────────────────────────────────────────
# E-posta / SMTP (şifre sıfırlama linki — opsiyonel)
# Boş bırakılırsa reset linki gönderilmez, server log'una yazılır (dev modu).
# ────────────────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=                       # boşsa SMTP_USER kullanılır
# SMTP_USE_TLS=true
